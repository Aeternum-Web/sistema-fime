@page "/"
@using SistemaFIME.Pages.Shared.Components.Cont

<PageTitle>Inicio - Comunidad Estudiantil FIME</PageTitle>

<div class="container py-5">
    <Shared.Components.Cont.HeroSection />

    <section class="mb-5">
        <h2 class="h3 fw-bold text-primary text-center mb-4">¿Qué puedes hacer aquí?</h2>
        <div class="row g-4">
            <Shared.Components.Cont.FeatureCard Icon="bi-question-circle-fill" IconColor="primary" Title="Resolver dudas" Description="Pregunta sobre materias, exámenes, profesores y recibe ayuda de la comunidad." />
            <Shared.Components.Cont.FeatureCard Icon="bi-journal-text" IconColor="danger" Title="Compartir apuntes" Description="Sube y descarga apuntes, guías y recursos útiles para tus materias." />
            <Shared.Components.Cont.FeatureCard Icon="bi-calendar-event" IconColor="warning" Title="Eventos y talleres" Description="Infórmate sobre eventos, talleres y actividades dentro y fuera de la facultad." />
            <Shared.Components.Cont.FeatureCard Icon="bi-emoji-laughing" IconColor="success" Title="Memes y comunidad" Description="Disfruta de memes, historias y haz nuevos amigos en un ambiente sano." />
        </div>
    </section>

    <section class="mb-5">
        <h2 class="h3 fw-bold text-primary text-center mb-4">Testimonios de la comunidad</h2>
        <div class="row g-4">
            <Shared.Components.Cont.TestimonialCard Name="Ana López" ImgUrl="https://ui-avatars.com/api/?name=Ana+López&background=3b82f6&color=fff&size=96" Testimony="Gracias a la comunidad resolví mi duda de Cálculo en minutos." />
            <Shared.Components.Cont.TestimonialCard Name="Pedro Martínez" ImgUrl="https://ui-avatars.com/api/?name=Pedro+Martinez&background=16a34a&color=fff&size=96" Testimony="Compartí mis apuntes y ahora tengo nuevos amigos." />
            <Shared.Components.Cont.TestimonialCard Name="Karla Reyes" ImgUrl="https://ui-avatars.com/api/?name=Karla+Reyes&background=fbbf24&color=fff&size=96" Testimony="¡Los eventos publicados aquí son lo mejor de FIME!" />
        </div>
    </section>

    <section class="mb-5 text-center">
        <h2 class="h5 fw-bold text-primary mb-3">¡Síguenos en redes sociales!</h2>
        <div class="d-flex flex-column flex-sm-row justify-content-center gap-3 mb-3">
            <Shared.Components.Cont.SocialButton Href="#" Icon="bi-facebook" BtnClass="btn-primary" Text="Facebook" />
            <Shared.Components.Cont.SocialButton Href="#" Icon="bi-instagram" BtnClass="btn-danger" Text="Instagram" />
            <Shared.Components.Cont.SocialButton Href="#" Icon="bi-telegram" BtnClass="btn-info text-white" Text="Telegram" />
        </div>
        <div class="text-secondary">#OrgulloFIME #ComunidadEstudiantil</div>
    </section>

    <Shared.Components.Cont.StatsSection Stats="@stats" />
</div>

@code {
    private DateTime connectionTime = DateTime.Now;
    private List<Shared.Components.Cont.StatsSection.StatItem> stats = new();

    protected override void OnInitialized()
    {
        connectionTime = DateTime.Now;
        stats = new List<Shared.Components.Cont.StatsSection.StatItem>
        {
            new Shared.Components.Cont.StatsSection.StatItem { Value = DateTime.Now.Year.ToString(), Label = "Año actual" },
            new Shared.Components.Cont.StatsSection.StatItem { Value = connectionTime.ToString("HH:mm"), Label = "Hora del servidor" },
            new Shared.Components.Cont.StatsSection.StatItem { Value = "v1.0", Label = "Versión" }
        };
    }
}