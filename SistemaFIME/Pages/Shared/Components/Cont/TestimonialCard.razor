@* Componente reutilizable para testimonios *@
@code {
    [Parameter] public string Name { get; set; }
    [Parameter] public string ImgUrl { get; set; }
    [Parameter] public string Testimony { get; set; }
}
<div class="col-md-4">
    <div class="card h-100 border-0 shadow-sm text-center">
        <div class="card-body">
            <img src="@ImgUrl" alt="@Name" class="rounded-circle mb-3 shadow" width="80" height="80" />
            <blockquote class="blockquote mb-2"><small>@Testimony</small></blockquote>
            <footer class="blockquote-footer"><i class="bi bi-person-circle"></i> @Name</footer>
        </div>
    </div>
</div>
